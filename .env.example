# Alpaca paper trading (https://alpaca.markets — free, no SSN required for paper)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true

# Claude API for the multi-agent debate + nightly post-mortem
ANTHROPIC_API_KEY=

# Optional: Slack webhook for daily digest
SLACK_WEBHOOK=

# Tuning
# Strategy params (defaults set from walk-forward winner, 2015-2025)
TOP_N=5
LOOKBACK_MONTHS=12
USE_REGIME_FILTER=false   # 200-day MA filter whipsaws — leave off until faster regime detector ships
USE_DEBATE=true
DRY_RUN=false
CRITIC_MODEL=claude-sonnet-4-6
POSTMORTEM_MODEL=claude-opus-4-7
